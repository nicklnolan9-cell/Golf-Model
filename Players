<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Players Championship 2026 — Betting Model</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500;600&family=Libre+Baskerville:ital@1&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#060a07;
  --surface:#0c1210;
  --surface2:#111a14;
  --surface3:#162019;
  --border:#1e2e22;
  --gold:#c9a84c;
  --gold-light:#e8cc7a;
  --gold-dim:#8a6e30;
  --green:#3ddc84;
  --blue:#4caacc;
  --red:#e05252;
  --orange:#e08c3a;
  --text:#d8e4da;
  --muted:#3d5442;
  --muted2:#6b8a72;
  --fairway:#1a3d22;
  --rough:#0f2614;
}

* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; }
body { background:var(--bg); color:var(--text); font-family:'DM Sans',sans-serif; min-height:100vh; overflow-x:hidden; }

/* ══════════════════════════════════════
   HERO — dramatic split layout
══════════════════════════════════════ */
.hero {
  position:relative;
  min-height:260px;
  background: linear-gradient(135deg, #020805 0%, #061210 35%, #04100c 65%, #060a06 100%);
  overflow:hidden;
  border-bottom: 1px solid var(--border);
}

/* Animated fairway stripes in background */
.fairway-stripes {
  position:absolute; inset:0; opacity:.07;
  background: repeating-linear-gradient(
    -15deg,
    transparent 0px,
    transparent 28px,
    #2d7040 28px,
    #2d7040 56px
  );
  animation: stripeDrift 20s linear infinite;
}
@keyframes stripeDrift { from{background-position:0 0;} to{background-position:100px 200px;} }

/* Corner decorative crest rings */
.hero-ring {
  position:absolute;
  border-radius:50%;
  border:1px solid rgba(201,168,76,.08);
  pointer-events:none;
}
.ring1 { width:500px; height:500px; top:-200px; right:-150px; }
.ring2 { width:340px; height:340px; top:-120px; right:-60px; border-color:rgba(201,168,76,.12); }
.ring3 { width:180px; height:180px; top:-40px; right:60px; border-color:rgba(201,168,76,.18); }

/* Left gold bar accent */
.hero::before {
  content:'';
  position:absolute;
  left:0; top:0; bottom:0;
  width:3px;
  background: linear-gradient(180deg, transparent, var(--gold), transparent);
}

.hero-layout {
  position:relative; z-index:2;
  display:flex; align-items:stretch;
  min-height:240px;
}

/* Left — main identity */
.hero-left {
  flex:1; padding:32px 36px 28px;
  display:flex; flex-direction:column; justify-content:space-between;
  border-right:1px solid rgba(201,168,76,.1);
}

.brand-row {
  display:flex; align-items:center; gap:18px; margin-bottom:14px;
}

/* ── CREST LOGO ── */
.crest-logo {
  width:64px; height:72px; flex-shrink:0;
  filter: drop-shadow(0 0 16px rgba(201,168,76,.35)) drop-shadow(0 2px 4px rgba(0,0,0,.6));
}

.brand-text {}
.brand-eyebrow {
  font-family:'DM Mono',monospace;
  font-size:8.5px; letter-spacing:.25em;
  text-transform:uppercase; color:var(--gold);
  display:flex; align-items:center; gap:8px; margin-bottom:5px;
}
.brand-eyebrow::after { content:''; flex:1; max-width:40px; height:1px; background:var(--gold); opacity:.4; }
.brand-title {
  font-family:'Bebas Neue',sans-serif;
  font-size:58px; letter-spacing:.04em; line-height:.92;
  color:#fff;
  text-shadow: 0 0 60px rgba(201,168,76,.12);
}
.brand-title em {
  color:var(--gold);
  font-style:normal;
}
.brand-champ {
  font-family:'DM Mono',monospace;
  font-size:11px; letter-spacing:.2em;
  text-transform:uppercase; color:var(--muted2);
  margin-top:4px;
}

.hero-meta {
  display:flex; flex-wrap:wrap; gap:16px; align-items:center;
}
.meta-item {
  display:flex; align-items:center; gap:7px;
  font-family:'DM Mono',monospace;
  font-size:10px; color:var(--muted2); letter-spacing:.06em;
}
.meta-item svg { opacity:.5; flex-shrink:0; }
.meta-divider { width:1px; height:14px; background:var(--border); }

/* Right — Island Green + stats */
.hero-right {
  width:340px; flex-shrink:0;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  padding:24px 28px;
  position:relative;
  background: radial-gradient(ellipse at center, rgba(22,50,28,.5) 0%, transparent 70%);
}

.island-label {
  font-family:'DM Mono',monospace;
  font-size:8px; letter-spacing:.2em;
  text-transform:uppercase; color:var(--muted2);
  margin-bottom:10px;
  display:flex; align-items:center; gap:8px;
}
.island-label::before, .island-label::after {
  content:''; flex:1; height:1px; background:var(--border);
}

.island-svg-wrap {
  filter: drop-shadow(0 8px 24px rgba(61,220,132,.12)) drop-shadow(0 0 8px rgba(201,168,76,.08));
  animation: islandFloat 6s ease-in-out infinite;
}
@keyframes islandFloat {
  0%,100% { transform:translateY(0); }
  50% { transform:translateY(-5px); }
}

/* ── STAT CHIPS under island ── */
.hero-chips {
  display:flex; gap:8px; margin-top:16px; flex-wrap:wrap; justify-content:center;
}
.chip {
  background: rgba(201,168,76,.06);
  border:1px solid rgba(201,168,76,.15);
  border-radius:20px;
  padding:4px 12px;
  font-family:'DM Mono',monospace;
  font-size:9px; letter-spacing:.1em;
  text-transform:uppercase; color:var(--gold);
}

/* ══════════════════════════════════════
   GOLF BALL DIVIDER
══════════════════════════════════════ */
.ball-divider {
  display:flex; align-items:center; gap:0;
  background:var(--surface);
  border-bottom:1px solid var(--border);
  padding:0 36px;
}
.ball-divider-line { flex:1; height:1px; background: linear-gradient(90deg, transparent, var(--border), transparent); }
.ball-icon-wrap { padding:0 20px; }

/* ══════════════════════════════════════
   SUMMARY STRIP — scorecard style
══════════════════════════════════════ */
.summary-strip {
  display:flex;
  background: linear-gradient(180deg, var(--surface) 0%, var(--surface2) 100%);
  border-bottom:2px solid var(--gold);
  position:relative;
  overflow:hidden;
}
.summary-strip::before {
  content:'';
  position:absolute; top:0; left:0; right:0; height:1px;
  background: linear-gradient(90deg, transparent, rgba(201,168,76,.3), transparent);
}
.strip-item {
  flex:1; padding:13px 18px;
  border-right:1px solid var(--border);
  display:flex; flex-direction:column; gap:3px;
  position:relative;
}
.strip-item:last-child { border-right:none; }
.strip-item:hover { background:rgba(201,168,76,.03); }
.strip-label {
  font-family:'DM Mono',monospace;
  font-size:8px; letter-spacing:.16em;
  text-transform:uppercase; color:var(--muted);
}
.strip-value {
  font-family:'Bebas Neue',sans-serif;
  font-size:20px; letter-spacing:.05em;
}
.strip-sub { font-size:10.5px; color:var(--muted2); }

/* ══════════════════════════════════════
   METHOD BAR
══════════════════════════════════════ */
.method-row {
  background:#050908;
  border-bottom:1px solid var(--border);
  padding:10px 36px;
  display:flex; gap:24px; align-items:center; flex-wrap:wrap;
}
.method-lbl {
  font-family:'DM Mono',monospace;
  font-size:8.5px; letter-spacing:.18em;
  color:var(--gold); text-transform:uppercase; white-space:nowrap;
}
.m-item {
  display:flex; align-items:center; gap:6px;
  font-size:11px; color:var(--muted2);
}
.m-dot { width:6px; height:6px; border-radius:50%; flex-shrink:0; }

/* ══════════════════════════════════════
   TABS — leaderboard scoreboard style
══════════════════════════════════════ */
.tabs {
  display:flex; padding:0 36px;
  border-bottom:1px solid var(--border);
  background:var(--surface);
  position:relative;
}
.tabs::before {
  content:'THE PLAYERS 2026';
  position:absolute; right:36px; top:50%; transform:translateY(-50%);
  font-family:'DM Mono',monospace;
  font-size:8px; letter-spacing:.2em;
  color:var(--muted); opacity:.4;
}
.tab {
  padding:12px 22px;
  font-family:'DM Mono',monospace;
  font-size:10.5px; letter-spacing:.1em;
  color:var(--muted); cursor:pointer;
  border-bottom:2px solid transparent;
  transition:all .15s; text-transform:uppercase;
  display:flex; align-items:center; gap:7px;
}
.tab.active { color:var(--gold); border-bottom-color:var(--gold); }
.tab:hover:not(.active) { color:var(--text); }
.panel { display:none; }
.panel.active { display:block; }

/* ══════════════════════════════════════
   NOTE BAR
══════════════════════════════════════ */
.note-bar {
  margin:16px 36px 0;
  background:rgba(201,168,76,.04);
  border:1px solid rgba(201,168,76,.12);
  border-left:3px solid var(--gold);
  border-radius:0 4px 4px 0;
  padding:10px 14px;
  font-size:12px; color:var(--muted2); line-height:1.6;
}
.note-bar strong { color:var(--gold); }

/* ══════════════════════════════════════
   TABLE — scorecard aesthetic
══════════════════════════════════════ */
.table-wrap { padding:14px 36px 40px; overflow-x:auto; }
table { width:100%; border-collapse:collapse; }
thead tr {
  background: linear-gradient(180deg, var(--surface2) 0%, var(--surface) 100%);
  border-bottom:2px solid var(--border);
}
th {
  font-family:'DM Mono',monospace;
  font-size:8.5px; letter-spacing:.12em;
  text-transform:uppercase; color:var(--muted);
  padding:9px 10px; text-align:left;
  white-space:nowrap; cursor:pointer; user-select:none;
}
th:hover { color:var(--text); }
th.right, td.right { text-align:right; }
tbody tr {
  border-bottom:1px solid rgba(30,46,34,.8);
  transition:background .1s;
}
tbody tr:hover { background:var(--surface2); }
tbody tr.top-val { background:rgba(61,220,132,.04); }
tbody tr.top-val:hover { background:rgba(61,220,132,.08); }
tbody tr.is-fade { background:rgba(224,82,82,.03); }
tbody tr.is-fade:hover { background:rgba(224,82,82,.06); }
td { padding:10px; font-size:13px; vertical-align:middle; }
td.mono { font-family:'DM Mono',monospace; font-size:12px; }

.rank { font-family:'DM Mono',monospace; font-size:11px; color:var(--muted); }
.r1 { color:var(--gold); font-weight:700; font-size:13px; }
.r2 { color:var(--muted2); }
.player-name { font-weight:500; }
.hist-tag {
  font-size:9.5px; font-family:'DM Mono',monospace;
  color:var(--blue); background:rgba(76,170,204,.1);
  padding:1px 6px; border-radius:2px; margin-left:6px;
}
.sg-pos { color:var(--green); }
.sg-neg { color:var(--red); }
.sg-neu { color:var(--muted2); }

.score-cell { display:flex; align-items:center; gap:8px; justify-content:flex-end; }
.score-bar-bg { width:48px; height:3px; background:var(--border); border-radius:2px; }
.score-bar-fill { height:3px; border-radius:2px; background:linear-gradient(90deg, var(--gold-dim), var(--gold)); }
.score-num {
  font-family:'Bebas Neue',sans-serif;
  font-size:18px; letter-spacing:.04em;
  min-width:34px; text-align:right;
}
.pill {
  display:inline-block;
  font-family:'DM Mono',monospace;
  font-size:11px; font-weight:500;
  padding:3px 9px; border-radius:3px;
}
.p-hi { background:rgba(61,220,132,.12); color:var(--green); }
.p-md { background:rgba(76,170,204,.12); color:var(--blue); }
.p-lo { background:rgba(107,138,114,.1); color:var(--muted2); }
.p-vlo { background:rgba(61,84,66,.08); color:var(--muted); }

.mkt-imp { font-family:'DM Mono',monospace; font-size:12px; color:var(--muted2); }
.edge-pos { font-family:'DM Mono',monospace; font-size:12px; font-weight:600; color:var(--green); }
.edge-neg { font-family:'DM Mono',monospace; font-size:12px; color:var(--red); }
.edge-neu { font-family:'DM Mono',monospace; font-size:12px; color:var(--muted); }

.vbadge {
  font-family:'DM Mono',monospace;
  font-size:8.5px; letter-spacing:.1em;
  text-transform:uppercase; padding:3px 8px;
  border-radius:3px; border:1px solid; white-space:nowrap;
}
.v-fire { border-color:var(--green); color:var(--green); background:rgba(61,220,132,.09); }
.v-good { border-color:var(--blue); color:var(--blue); background:rgba(76,170,204,.07); }
.v-fair { border-color:var(--muted); color:var(--muted); }
.v-skip { border-color:transparent; color:var(--muted); }
.v-avoid { border-color:var(--red); color:var(--red); background:rgba(224,82,82,.07); }
.odds-disp { font-family:'DM Mono',monospace; font-size:12px; color:var(--muted2); }

/* ══════════════════════════════════════
   SECTION HEADERS
══════════════════════════════════════ */
.sec-hdr {
  padding:22px 36px 10px;
  display:flex; align-items:center; gap:14px;
}
.sec-icon-wrap {
  width:32px; height:32px; flex-shrink:0;
  border-radius:50%;
  display:flex; align-items:center; justify-content:center;
}
.sec-icon-wrap.green { background:rgba(61,220,132,.1); border:1px solid rgba(61,220,132,.2); }
.sec-icon-wrap.blue { background:rgba(76,170,204,.1); border:1px solid rgba(76,170,204,.2); }
.sec-icon-wrap.red { background:rgba(224,82,82,.1); border:1px solid rgba(224,82,82,.2); }
.sec-title {
  font-family:'Bebas Neue',sans-serif;
  font-size:21px; letter-spacing:.08em;
}

/* ══════════════════════════════════════
   VALUE CARDS — premium card style
══════════════════════════════════════ */
.val-cards {
  display:grid; grid-template-columns:repeat(3,1fr);
  gap:14px; padding:0 36px 32px;
}
.val-card {
  background:var(--surface2);
  border:1px solid var(--border);
  border-radius:8px; padding:18px 20px;
  position:relative; overflow:hidden;
  transition: transform .15s, box-shadow .15s;
}
.val-card:hover {
  transform:translateY(-2px);
  box-shadow:0 8px 24px rgba(0,0,0,.4);
}
/* Top shimmer line */
.val-card::before {
  content:''; position:absolute;
  top:0; left:0; right:0; height:2px;
}
/* Golf flag watermark */
.val-card::after {
  content:'⛳';
  position:absolute; right:14px; bottom:10px;
  font-size:28px; opacity:.04;
  pointer-events:none;
}
.val-card.fire::before { background:linear-gradient(90deg,transparent,var(--green),transparent); }
.val-card.good::before { background:linear-gradient(90deg,transparent,var(--blue),transparent); }
.val-card.avoid::before { background:linear-gradient(90deg,transparent,var(--red),transparent); }
.val-card.fire { border-color:rgba(61,220,132,.22); }
.val-card.good { border-color:rgba(76,170,204,.18); }
.val-card.avoid { border-color:rgba(224,82,82,.18); }
.val-card-label {
  font-family:'DM Mono',monospace;
  font-size:8px; letter-spacing:.16em;
  text-transform:uppercase; margin-bottom:7px;
}
.val-card-name { font-size:16px; font-weight:600; color:var(--text); margin-bottom:4px; }
.val-card-odds {
  font-family:'DM Mono',monospace;
  font-size:11px; color:var(--muted2); margin-bottom:8px;
}
.val-card-edge {
  font-family:'DM Mono',monospace;
  font-size:15px; font-weight:700; margin-bottom:8px;
}
.val-card p { font-size:11.5px; color:var(--muted2); line-height:1.65; }

/* ══════════════════════════════════════
   FOOTER AREA
══════════════════════════════════════ */
.divider {
  width:calc(100% - 72px); margin:4px 36px 22px;
  height:1px; background:var(--border);
}
.footnote {
  padding:14px 36px 30px;
  font-family:'DM Mono',monospace;
  font-size:9.5px; color:var(--muted); line-height:1.8;
  border-top:1px solid var(--border);
  display:flex; gap:28px; flex-wrap:wrap; align-items:flex-start;
}
.footnote-col { flex:1; min-width:200px; }
.footnote-logo {
  flex-shrink:0;
  filter:opacity(.2);
}

th.sorted { color:var(--gold); }
th.sorted::after { content:' ▼'; font-size:7px; }
th.sorted.asc::after { content:' ▲'; }

/* ══════════════════════════════════════
   MOBILE
══════════════════════════════════════ */
@media(max-width:680px){
  .hero-right { display:none; }
  .hero-layout { min-height:auto; }
  .hero-left { padding:22px 18px 18px; border-right:none; }
  .brand-title { font-size:42px; }
  .brand-row { gap:14px; }
  .crest-logo { width:48px; height:54px; }

  .summary-strip { flex-direction:column; }
  .strip-item { border-right:none; border-bottom:1px solid var(--border); padding:11px 18px; }
  .strip-item:last-child { border-bottom:none; }

  .method-row { display:none; }
  .ball-divider { display:none; }

  .tabs { padding:0 14px; }
  .tabs::before { display:none; }
  .tab { padding:10px 14px; font-size:10px; }

  .note-bar { margin:12px 14px 0; }
  .table-wrap { padding:10px 0 30px; }
  th, td { padding:7px 6px; font-size:11px; }
  .score-bar-bg { display:none; }
  .score-num { font-size:14px; }

  .val-cards { grid-template-columns:1fr; padding:0 14px 24px; }
  .sec-hdr { padding:18px 14px 8px; }
  .divider { width:calc(100% - 28px); margin:4px 14px 18px; }
  .footnote { padding:14px 14px 24px; flex-direction:column; gap:14px; }
  .footnote-logo { display:none; }
}
</style>
</head>
<body>

<!-- ══════════ HERO ══════════ -->
<div class="hero">
  <div class="fairway-stripes"></div>
  <div class="hero-ring ring1"></div>
  <div class="hero-ring ring2"></div>
  <div class="hero-ring ring3"></div>

  <div class="hero-layout">

    <!-- LEFT SIDE -->
    <div class="hero-left">
      <div>
        <div class="brand-row">

          <!-- CREST LOGO: shield with flag + golf ball -->
          <svg class="crest-logo" viewBox="0 0 64 72" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Shield outline -->
            <path d="M4 6 L32 2 L60 6 L60 40 Q60 62 32 70 Q4 62 4 40 Z"
              fill="url(#shieldGrad)" stroke="#c9a84c" stroke-width="1.2"/>
            <path d="M8 9 L32 5.5 L56 9 L56 40 Q56 59 32 66.5 Q8 59 8 40 Z"
              fill="none" stroke="rgba(201,168,76,.25)" stroke-width=".8"/>
            <!-- Inner shield top bar -->
            <rect x="8" y="9" width="48" height="14" rx="1" fill="rgba(201,168,76,.08)"/>
            <!-- Crossed clubs (simplified X) -->
            <line x1="16" y1="52" x2="48" y2="26" stroke="rgba(201,168,76,.35)" stroke-width="1.8" stroke-linecap="round"/>
            <line x1="48" y1="52" x2="16" y2="26" stroke="rgba(201,168,76,.35)" stroke-width="1.8" stroke-linecap="round"/>
            <!-- Golf ball center -->
            <circle cx="32" cy="39" r="9" fill="url(#ballGrad)" stroke="rgba(201,168,76,.4)" stroke-width=".8"/>
            <!-- Dimple pattern -->
            <circle cx="29" cy="36" r="1.2" fill="rgba(0,0,0,.3)"/>
            <circle cx="33" cy="35" r="1" fill="rgba(0,0,0,.25)"/>
            <circle cx="36" cy="38" r="1.1" fill="rgba(0,0,0,.28)"/>
            <circle cx="29" cy="41" r="1" fill="rgba(0,0,0,.25)"/>
            <circle cx="33" cy="43" r="1.2" fill="rgba(0,0,0,.3)"/>
            <circle cx="35.5" cy="41" r=".9" fill="rgba(0,0,0,.2)"/>
            <!-- Flag pin on top -->
            <rect x="31.2" y="13" width="1.8" height="14" fill="#c9a84c" rx=".9"/>
            <path d="M33 13 L33 20 L40 16.5 Z" fill="#c9a84c" opacity=".9"/>
            <!-- Star at bottom of shield -->
            <text x="32" y="60" text-anchor="middle" font-size="7" fill="rgba(201,168,76,.5)" font-family="sans-serif">★ ★ ★</text>
            <defs>
              <linearGradient id="shieldGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#0d2218"/>
                <stop offset="100%" stop-color="#060e09"/>
              </linearGradient>
              <radialGradient id="ballGrad" cx="40%" cy="35%">
                <stop offset="0%" stop-color="#e8e8e8"/>
                <stop offset="60%" stop-color="#b0b8b0"/>
                <stop offset="100%" stop-color="#6a7a6a"/>
              </radialGradient>
            </defs>
          </svg>

          <div class="brand-text">
            <div class="brand-eyebrow">2026 Betting Model &nbsp;·&nbsp; v3.0</div>
            <div class="brand-title">THE <em>PLAYERS</em></div>
            <div class="brand-champ">Championship &nbsp;·&nbsp; TPC Sawgrass</div>
          </div>
        </div>

        <div class="hero-meta">
          <!-- Location pin -->
          <div class="meta-item">
            <svg width="12" height="14" viewBox="0 0 12 14" fill="none">
              <path d="M6 0C3.24 0 1 2.24 1 5c0 3.75 5 9 5 9s5-5.25 5-9c0-2.76-2.24-5-5-5z" fill="#c9a84c"/>
              <circle cx="6" cy="5" r="2" fill="#060a07"/>
            </svg>
            Ponte Vedra Beach, FL
          </div>
          <div class="meta-divider"></div>
          <!-- Calendar -->
