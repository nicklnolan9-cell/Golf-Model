function computeScore(p){const r=p[1]*.35+p[2]*.25+p[3]*.20+p[4]*.10+p[5]*.10;return r*(1+p[6]);}
function americanToRaw(o){return o>0?100/(o+100):Math.abs(o)/(Math.abs(o)+100);}
function vigStripped(o){return americanToRaw(o)/1.07;}
const scored=RAW.map(p=>({p,s:computeScore(p)})).sort((a,b)=>b.s-a.s);
const maxS=scored[0].s,minS=Math.min(...scored.map(x=>x.s));
function modelTop10(s){const n=(s-minS)/(maxS-minS);return .04+n*n*.58;}
const rows=scored.map((item,i)=>{
  const p=item.p,s=item.s,t10=modelTop10(s),mktImp=vigStripped(p[7]),edge=t10-mktImp;
  return{rank:i+1,name:p[0],app:p[1],t2g:p[2],putt:p[3],ott:p[4],arg:p[5],hist:p[6],t10odds:p[7],notes:p[8],s,t10,mktImp,edge};
});

function dispName(n){return n.split(', ').reverse().join(' ');}
function histTag(h){if(h>=.10)return'<span class="hist-tag">2×HX</span>';if(h>=.05)return'<span class="hist-tag">HX</span>';return'';}
function sgClass(v){return v>.1?'sg-pos':v<-.1?'sg-neg':'sg-neu';}
function sgFmt(v){return`<td class="right mono ${sgClass(v)}">${v>0?'+':''}${v.toFixed(2)}</td>`;}
function pillClass(p){return p>=.45?'p-hi':p>=.30?'p-md':p>=.15?'p-lo':'p-vlo';}
function pct(v){return Math.round(v*100);}
function oddsDisp(o){return o>0?`+${o}`:`${o}`;}
function edgeClass(e){return e>.04?'edge-pos':e<-.04?'edge-neg':'edge-neu';}
function signalBadge(e){
  if(e>=.12)return'<span class="vbadge v-fire">★★ FIRE</span>';
  if(e>=.07)return'<span class="vbadge v-fire">★ VALUE</span>';
  if(e>=.03)return'<span class="vbadge v-good">▲ PLAY</span>';
  if(e>=-.02)return'<span class="vbadge v-fair">FAIR</span>';
  if(e<-.10)return'<span class="vbadge v-avoid">✕✕ FADE</span>';
  if(e<-.05)return'<span class="vbadge v-avoid">✕ FADE</span>';
  return'<span class="vbadge v-skip">SKIP</span>';
}

function buildStrip(){
  const topVal=rows.filter(r=>r.edge>0).sort((a,b)=>b.edge-a.edge)[0];
  const topValLong=rows.filter(r=>r.edge>0&&r.t10odds>=400).sort((a,b)=>b.edge-a.edge)[0];
  document.getElementById('strip').innerHTML=`
    <div class="strip-item"><div class="strip-label">Model #1 · No Bet</div><div class="strip-value" style="color:var(--gold)">Scheffler</div><div class="strip-sub">-200 T10 · Market has this right</div></div>
    <div class="strip-item"><div class="strip-label">★ Top Value Pick</div><div class="strip-value" style="color:var(--green)">${dispName(topVal.name).split(' ').pop()}</div><div class="strip-sub">${oddsDisp(topVal.t10odds)} T10 · +${pct(topVal.edge)}% edge vs. market</div></div>
    <div class="strip-item"><div class="strip-label">★ Best Longshot</div><div class="strip-value" style="color:var(--orange)">${dispName(topValLong.name).split(' ').pop()}</div><div class="strip-sub">${oddsDisp(topValLong.t10odds)} T10 · +${pct(topValLong.edge)}% edge</div></div>
    <div class="strip-item"><div class="strip-label">Si Woo Kim</div><div class="strip-value" style="color:var(--blue)">+240</div><div class="strip-sub">Leads field SG:T2G · Former winner · Value</div></div>
    <div class="strip-item"><div class="strip-label">✕ Key Fade</div><div class="strip-value" style="color:var(--red)">Schauffele</div><div class="strip-sub">+210 · 2026 form badly lags price</div></div>
  `;
}

function renderTable(data){
  const tbody=document.getElementById('main-tbody');tbody.innerHTML='';
  data.forEach(r=>{
    const isVal=r.edge>=.07,isFade=r.edge<=-.05;
    const tr=document.createElement('tr');
    if(isVal)tr.className='top-val';else if(isFade)tr.className='is-fade';
    const bw=Math.max(4,Math.min(100,(r.s/maxS)*100));
    const rCls=r.rank===1?'r1':r.rank<=3?'r2':'';
    tr.innerHTML=`
      <td class="rank ${rCls}">${r.rank}</td>
      <td class="player-name">${dispName(r.name)}${histTag(r.hist)}</td>
      <td class="right"><div class="score-cell"><div class="score-bar-bg"><div class="score-bar-fill" style="width:${bw}%"></div></div><span class="score-num" style="color:${r.rank===1?'var(--gold)':r.rank<=3?'var(--muted2)':'var(--text)'}">${r.s.toFixed(2)}</span></div></td>
      ${sgFmt(r.app)}${sgFmt(r.t2g)}${sgFmt(r.putt)}${sgFmt(r.ott)}${sgFmt(r.arg)}
      <td class="right"><span class="pill ${pillClass(r.t10)}">${pct(r.t10)}%</span></td>
      <td class="right odds-disp">${oddsDisp(r.t10odds)}</td>
      <td class="right mkt-imp">${pct(r.mktImp)}%</td>
      <td class="right ${edgeClass(r.edge)}">${r.edge>0?'+':''}${pct(r.edge)}%</td>
      <td>${signalBadge(r.edge)}</td>
    `;
    tbody.appendChild(tr);
  });
}

renderTable(rows);buildStrip();

let sortCol=0,sortAsc=false;
function sortTable(col){
  if(sortCol===col)sortAsc=!sortAsc;else{sortCol=col;sortAsc=false;}
  document.querySelectorAll('th').forEach((th,i)=>{th.classList.remove('sorted','asc');if(i===col){th.classList.add('sorted');if(sortAsc)th.classList.add('asc');}});
  const getVal=(r,c)=>[r.rank,r.name,r.s,r.app,r.t2g,r.putt,r.ott,r.arg,r.t10,r.t10odds,r.mktImp,r.edge,0][c];
  const sorted=[...rows].sort((a,b)=>{const va=getVal(a,col),vb=getVal(b,col);if(typeof va==='string')return sortAsc?va.localeCompare(vb):vb.localeCompare(va);return sortAsc?va-vb:vb-va;});
  renderTable(sorted);
}

function renderValCards(arr,id,cls,labelText,labelColor){
  const c=document.getElementById(id);if(!c)return;
  if(arr.length===0){c.innerHTML='<p style="color:var(--muted);font-size:13px">None.</p>';return;}
  arr.slice(0,6).forEach(r=>{
    const div=document.createElement('div');div.className=`val-card ${cls}`;
    div.innerHTML=`
      <div class="val-card-label" style="color:${labelColor}">${labelText}</div>
      <div class="val-card-name">${dispName(r.name)}${histTag(r.hist)}</div>
      <div class="val-card-odds">T10 odds: ${oddsDisp(r.t10odds)} &nbsp;&middot;&nbsp; Model: ${pct(r.t10)}% &nbsp;&middot;&nbsp; Mkt: ${pct(r.mktImp)}%</div>
      <div class="val-card-edge" style="color:${r.edge>0?'var(--green)':'var(--red)'}">${r.edge>0?'+':''}${pct(r.edge)}% edge</div>
      <p>${r.notes}</p>
    `;
    c.appendChild(div);
  });
}

const strongVals=rows.filter(r=>r.edge>=.07).sort((a,b)=>b.edge-a.edge);
const goodVals=rows.filter(r=>r.edge>=.03&&r.edge<.07).sort((a,b)=>b.edge-a.edge);
const fades=rows.filter(r=>r.edge<=-.05).sort((a,b)=>a.edge-b.edge);
renderValCards(strongVals,'strong-vals','fire','★ Strong Value','var(--green)');
renderValCards(goodVals,'good-vals','good','▲ Good Value','var(--blue)');
renderValCards(fades,'fade-cards','avoid','✕ Fade','var(--red)');

function showTab(id,el){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('tab-'+id).classList.add('active');
}
